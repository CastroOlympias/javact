cat << 'EOF' > .gitignore
# --- IDE and System Files ---
.vscode/
.DS_Store
Thumbs.db

# --- Java/Maven Build Outputs (Server) ---
server/target/
server/.mvn/
server/mvnw.cmd
server/mvnw

# --- Angular/Node Dependencies (Client) ---
client/node_modules/
client/dist/
client/.angular/
node_modules/

# --- Environment Variables ---
.env
.env.local
EOF

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
